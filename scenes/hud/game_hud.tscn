[gd_scene format=3 uid="uid://game_hud_scene"]

[ext_resource type="Script" uid="uid://game_hud_script" path="res://scenes/hud/game_hud.gd" id="1_hud"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_hud_bg"]
bg_color = Color(0.0, 0.0, 0.0, 0.75)
border_width_bottom = 1
border_color = Color(0.0, 0.8, 0.0, 1)

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_health_fill"]
bg_color = Color(0.0, 0.8, 0.1, 1)

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_health_bg"]
bg_color = Color(0.1, 0.1, 0.1, 1)

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_gameover_bg"]
bg_color = Color(0.0, 0.0, 0.0, 0.92)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.8, 0.1, 0.1, 1)

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_btn"]
bg_color = Color(0.5, 0.05, 0.05, 1)
border_width_left = 1
border_width_top = 1
border_width_right = 1
border_width_bottom = 1
border_color = Color(1.0, 0.2, 0.2, 1)

[node name="GameHUD" type="CanvasLayer"]
script = ExtResource("1_hud")

[node name="VBox" type="VBoxContainer" parent="."]
offset_left = 8.0
offset_top = 8.0
offset_right = 300.0
offset_bottom = 100.0
theme_override_constants/separation = 4
theme_override_styles/panel = SubResource("StyleBoxFlat_hud_bg")

[node name="HealthBar" type="ProgressBar" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(280, 18)
min_value = 0.0
max_value = 100.0
value = 100.0
theme_override_styles/fill = SubResource("StyleBoxFlat_health_fill")
theme_override_styles/background = SubResource("StyleBoxFlat_health_bg")

[node name="TimerLabel" type="Label" parent="VBox"]
layout_mode = 2
text = "UPTIME: 00:00"
theme_override_font_sizes/font_size = 13
theme_override_colors/font_color = Color(0.0, 1.0, 0.2, 1)

[node name="AlertsLabel" type="Label" parent="VBox"]
layout_mode = 2
text = ""
theme_override_font_sizes/font_size = 11
theme_override_colors/font_color = Color(1.0, 0.3, 0.3, 1)

[node name="GameOverOverlay" type="Control" parent="."]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
visible = false

[node name="DarkBG" type="ColorRect" parent="GameOverOverlay"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.0, 0.0, 0.0, 0.7)

[node name="Panel" type="PanelContainer" parent="GameOverOverlay"]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -200.0
offset_top = -120.0
offset_right = 200.0
offset_bottom = 120.0
theme_override_styles/panel = SubResource("StyleBoxFlat_gameover_bg")

[node name="VBox" type="VBoxContainer" parent="GameOverOverlay/Panel"]
layout_mode = 2
theme_override_constants/separation = 16

[node name="TitleLabel" type="Label" parent="GameOverOverlay/Panel/VBox"]
layout_mode = 2
text = "⚡ SYSTEM MELTDOWN ⚡"
theme_override_font_sizes/font_size = 22
theme_override_colors/font_color = Color(1.0, 0.2, 0.2, 1)
horizontal_alignment = 1

[node name="UptimeLabel" type="Label" parent="GameOverOverlay/Panel/VBox"]
layout_mode = 2
text = "Total Uptime: 00:00"
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(0.8, 0.8, 0.8, 1)
horizontal_alignment = 1

[node name="ReturnButton" type="Button" parent="GameOverOverlay/Panel/VBox"]
layout_mode = 2
text = "Return to Menu"
theme_override_colors/font_color = Color(1.0, 0.3, 0.3, 1)
theme_override_styles/normal = SubResource("StyleBoxFlat_btn")

[connection signal="pressed" from="GameOverOverlay/Panel/VBox/ReturnButton" to="." method="_on_return_to_menu_pressed"]
